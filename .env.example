# ── Supabase Postgres ────────────────────────────────────────
# Pooler URL (PgBouncer transaction-mode) for the running app.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode pooler — used by `prisma migrate dev` / `prisma db push`.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ── Admin session ────────────────────────────────────────────
# 32+ char random string used to sign admin session JWTs.
# Generate with:   openssl rand -base64 48
ADMIN_SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# ── Whitelist API key (Roblox game server) ───────────────────
# Shared secret the Roblox game server sends in `x-api-key` header
# when calling GET /api/checkwhitelist.
# Generate with:   openssl rand -hex 32
WHITELIST_API_KEY="replace-with-a-long-random-hex-string"

# ── Stripe ───────────────────────────────────────────────────
# From Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# (CLI prints the signing secret once on start).
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public origin used for Stripe success/cancel callback URLs.
# Optional — defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=""

# ── Storage driver (admin file uploads) ─────────────────────
# "local"    → writes to public/uploads/ — great for dev & self-hosted.
# "supabase" → uploads to Supabase Storage (needs the keys below).
# Leave blank → auto-pick supabase if configured, else local.
STORAGE_DRIVER="local"

# Optional: only needed when STORAGE_DRIVER=supabase (or auto-detect).
# Create a public bucket named `product-assets` in Supabase Dashboard → Storage.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
