# ── Dependencies ───────────────────────────────────────────
node_modules
/.pnp
.pnp.js

# ── Next.js build output ───────────────────────────────────
.next
/out
/build

# ── Env files (KEEP .env.example so devs see what's required) ──
.env
.env*.local

# ── OS / IDE ───────────────────────────────────────────────
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea

# ── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Test / coverage ────────────────────────────────────────
/coverage

# ── Logs ───────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Deploy / hosting ───────────────────────────────────────
.vercel

# ── Certs ──────────────────────────────────────────────────
*.pem

# ── Prisma — generated client lives in node_modules (default), but ignore
# any custom output dir as well.
/src/generated

# ── Local uploads from the admin panel (when STORAGE_DRIVER=local).
# Kept out of git so commits aren't bloated by binary assets.
/public/uploads

# ── Audit script outputs (Lighthouse + axe reports + screenshots).
# Regenerated by `npm run audit` — not source of truth.
/audit

# ── Generated PDF — source is docs/manual/manual.html; rebuild with
# `npm run build:manual`.
/docs/manual/manual.pdf
