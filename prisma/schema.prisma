// ────────────────────────────────────────────────────────────
//  Judy Shop — Prisma schema
//  Supabase Postgres (pooler for runtime, direct URL for migrate)
//
//  i18n strategy: every customer-facing text field has paired
//  `<field>En` and `<field>Th` columns. Both required for content
//  consistency unless explicitly optional.
// ────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Catalogue ─────────────────────────────────────────────────

model Product {
  id   String @id @default(cuid())
  /// URL-friendly key, e.g. "judy-legend". Single-language, used in routes & external API.
  slug String @unique

  // i18n display fields
  nameEn             String
  nameTh             String
  shortNameEn        String?
  shortNameTh        String?
  descriptionEn      String  @db.Text
  descriptionTh      String  @db.Text
  shortDescriptionEn String?
  shortDescriptionTh String?

  badge         ProductBadge?
  /// Roblox place/game ID this whitelist applies to.
  gameId        String?
  /// Optional link to the Roblox game itself — "Open game" CTA on
  /// the success page. Distinct from gameId (numeric, for whitelist
  /// lookups) so the admin can pin a marketing URL with slug.
  gameLinkUrl   String?
  /// Optional external link shown on the success page after a paying
  /// customer's order is fulfilled. Sits below "Open game" and above
  /// the preset download list — typically a setup guide / Drive link.
  gamePresetUrl String?
  /// Affiliate / partner-store link. When set, this product is NOT sold
  /// through our own checkout — it's a referral card. The public shop
  /// renders it with an outbound "Buy at partner store" button (opens in
  /// a new tab) instead of the plan/payment modal, and the product needs
  /// no Plan rows. Store the full ready-made link the partner gave us,
  /// including their ref query (e.g.
  /// "https://aclassstore.com/products/ac-jump-evo?ref=JUDY-STUDIO").
  externalUrl   String?
  isActive      Boolean       @default(true)
  comingSoon    Boolean       @default(false)
  /// Smaller value = appears first.
  displayOrder  Int           @default(0)

  /// Allow visitors to claim a short timed trial (no payment) for this product.
  trialEnabled Boolean @default(false)
  /// Trial duration in minutes. Only honoured when trialEnabled=true.
  trialMinutes Int     @default(10)

  images       ProductImage[]
  plans        Plan[]
  orders       Order[]
  whitelist    Whitelist[]
  giftOverlays GiftOverlay[]
  presets      Preset[]
  trialUsage   TrialUsage[]
  /// Revenue-share allocations to business partners. The sum of all
  /// rows here can be 0 to 100 — whatever is left over (100 − Σ) is
  /// the "shared pool" (เงินกลาง), implicitly owned by the house.
  partners     ProductPartner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, displayOrder])
}

enum ProductBadge {
  HOT
  NEW
  SALE
}

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  url          String
  altEn        String?
  altTh        String?
  displayOrder Int     @default(0)
  /// First-pick image for grids. Only one per product should be true.
  isThumbnail  Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId, displayOrder])
}

model Plan {
  id        String @id @default(cuid())
  productId String

  // i18n
  labelEn String
  labelTh String

  /// Length of access in days. NULL when isLifetime.
  durationDays Int?
  isLifetime   Boolean @default(false)
  /// Baht price (supports satang via 2-decimal precision).
  priceTHB     Decimal @db.Decimal(10, 2)
  /// USD equivalent — display only. Can be auto-derived from priceTHB.
  priceUSD     Decimal @db.Decimal(10, 2)
  /// When true, priceUSD is automatically refreshed from the FX rate.
  /// When false, the admin set it manually.
  usdAuto      Boolean @default(true)
  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, displayOrder])
}

// ── Whitelist (mirrors legacy whitelist.xlsx schema) ─────────
// Original columns: ID | Username | Expire Date | Label | Added At | Added By
// Admin-only notes are not localised.

model Whitelist {
  id         String          @id @default(cuid())
  productId  String
  username   String
  expireDate DateTime?
  isLifetime Boolean         @default(false)
  /// Admin note (legacy "Label" column). Single language.
  label      String?
  source     WhitelistSource @default(STRIPE)
  addedBy    String?
  addedAt    DateTime        @default(now())

  product Product @relation(fields: [productId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, username])
  @@index([username])
  @@index([productId, expireDate])
}

enum WhitelistSource {
  STRIPE
  PAYPAL
  MANUAL
  PROMO
  REFUND_REVERT
  TRIAL
}

/// Append-only journal of admin mutations.
/// Written by helpers in src/lib/audit.ts after every action so we can
/// answer "who deleted this whitelist entry?" / "who issued that refund?"
/// later. Never updated, never deleted by the app.
model AuditLog {
  id         String  @id @default(cuid())
  /// Admin's session sub (= AdminUser.id). Null only for system events.
  actorId    String?
  /// Snapshot of the admin's email at action time so renames are durable.
  actorEmail String?
  /// Free-form action key, e.g. "product.update", "order.refund", "whitelist.delete".
  action     String
  /// Optional pointer to the affected row (productId / orderId / etc).
  targetType String?
  targetId   String?
  /// Arbitrary JSON payload — diff, new values, reason. Capped client-side.
  payload    Json?
  /// Best-effort IP at action time.
  ip         String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

/// One row per trial start, used to rate-limit "1 trial per username per 24h".
/// We don't delete these rows when the customer later purchases — the
/// Whitelist row might churn but the history must survive.
model TrialUsage {
  id        String   @id @default(cuid())
  productId String
  username  String
  ip        String?
  userAgent String?  @db.Text
  startedAt DateTime @default(now())
  expiresAt DateTime

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, username, startedAt])
  @@index([username, startedAt])
}

// ── Orders / Transactions ─────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  productId     String
  planId        String
  username      String
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("THB")
  paymentMethod PaymentMethod
  status        OrderStatus   @default(PENDING)

  stripeSessionId String? @unique
  stripePaymentId String?

  /// PayPal Orders v2 — `paypalOrderId` is the unique id returned by
  /// /v2/checkout/orders, used as the idempotency key on capture.
  /// `paypalCaptureId` is the id of the capture record itself (one
  /// per Order, since we use intent=CAPTURE single-capture flow).
  paypalOrderId   String? @unique
  paypalCaptureId String?

  product   Product    @relation(fields: [productId], references: [id])
  plan      Plan       @relation(fields: [planId], references: [id])
  whitelist Whitelist?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([status, createdAt])
}

enum PaymentMethod {
  PROMPTPAY
  CARD
  PAYPAL
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ── Announcement banner (admin-managed popup on Home) ────────
// Either / both `messageEn|Th` and `imageUrl` can be set — the popup
// shows whichever the admin provides (poster-only is allowed).

model Announcement {
  id        String    @id @default(cuid())
  messageEn String?   @db.Text
  messageTh String?   @db.Text
  imageUrl  String?
  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)
  priority  Int       @default(0)

  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startDate, endDate])
}

// ── News (separate from Announcement — articles on /news) ────

model News {
  id          String       @id @default(cuid())
  category    NewsCategory @default(ANNOUNCE)
  titleEn     String
  titleTh     String
  excerptEn   String?      @db.Text
  excerptTh   String?      @db.Text
  imageUrl    String?
  publishedAt DateTime     @default(now())
  isPublished Boolean      @default(true)

  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, publishedAt])
}

enum NewsCategory {
  UPDATE
  ANNOUNCE
  EVENT
  MAINTENANCE
}

// ── Gift overlays (images shown for each TikTok gift) ─────────

model GiftOverlay {
  id        String @id @default(cuid())
  productId String

  // i18n display name (TikTok gift e.g. "Rose" / "ดอกกุหลาบ").
  giftNameEn String
  giftNameTh String

  imageUrl     String
  altEn        String?
  altTh        String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, displayOrder])
}

// ── Presets (downloadable config files for external programs) ─

model Preset {
  id        String @id @default(cuid())
  productId String

  // i18n
  nameEn        String
  nameTh        String
  descriptionEn String?
  descriptionTh String?

  /// Public download URL or Supabase Storage path.
  fileUrl       String
  fileName      String
  mimeType      String?
  fileSize      Int?
  /// Which program this preset targets (e.g. "OBS", "Streamlabs", "vMix").
  targetProgram String?
  /// Version string for the preset (e.g. "1.0.2").
  version       String?
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, displayOrder])
}

// ── Site settings (singleton row, id="singleton") ─────────────

model Setting {
  /// Always "singleton" — the table holds exactly one row.
  id               String  @id
  /// Percentage added to the cart total when paying by credit card.
  /// e.g. 3.00 → +3 % surcharge. PromptPay is not surcharged.
  cardFeePercent   Decimal @default(0) @db.Decimal(5, 2)
  /// Percentage added when paying by PayPal. PayPal fees in TH tend
  /// to be higher than Stripe card (cross-border + currency
  /// conversion), so this is usually set higher than `cardFeePercent`.
  paypalFeePercent Decimal @default(0) @db.Decimal(5, 2)

  /// Per-gateway kill switches. When false, the public checkout hides
  /// the option AND the server rejects any requests that try to use
  /// it — used to disable a method during an incident without a deploy.
  promptpayEnabled Boolean @default(true)
  cardEnabled      Boolean @default(true)
  paypalEnabled    Boolean @default(true)

  /// Admin-authored site rules — rendered on /[locale]/rules. Stored
  /// as TipTap-sanitized HTML (same pipeline as product descriptions).
  /// Two columns for i18n; both fall back to "" when unset.
  rulesContentEn String @default("") @db.Text
  rulesContentTh String @default("") @db.Text

  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ── How-to-use videos (admin-managed tutorial library) ────────
// Generic site-wide tutorials — NOT linked to a product. Public
// /[locale]/how-to-use page renders these as tabs (one card per
// video) with an embedded YouTube player below.
model HowToUseVideo {
  id            String  @id @default(cuid())
  titleEn       String
  titleTh       String
  descriptionEn String? @db.Text
  descriptionTh String? @db.Text
  /// Original YouTube URL as pasted by the admin. The embed iframe
  /// uses the parsed videoId so admins can paste any youtu.be /
  /// youtube.com/watch / youtube.com/shorts format.
  youtubeUrl    String
  /// Parsed video id (e.g. "dQw4w9WgXcQ"). Validated at write time
  /// so the public page never has to handle a bad URL.
  videoId       String
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, displayOrder])
}

// ── Stripe webhook dedup ──────────────────────────────────────
// Stripe redelivers the same event for up to ~3 days on non-2xx
// responses, so the webhook handler must reject replays. We INSERT
// one row per successfully-processed event id; the primary key
// rejects duplicates atomically, so Stripe's retries return 200 OK
// no-ops instead of re-running fulfilment side-effects.

model WebhookEvent {
  /// Stripe's `evt_…` id. Globally unique per event.
  id         String   @id
  /// e.g. "checkout.session.completed". Recorded for ops debugging only —
  /// dedup decisions are made on `id` alone.
  type       String
  /// When we first processed it. Useful to audit "did this event ever
  /// reach us" during a Stripe vs DB reconciliation.
  receivedAt DateTime @default(now())

  @@index([type, receivedAt])
}

// ── App users (admins + partners) ─────────────────────────────
// Historically single-admin; now every login is an AdminUser carrying
// a `role`. ADMIN = full back-office (/admin). PARTNER = scoped portal
// (/partner) that only ever sees its own Partner's products + revenue.
// `partnerId` links a PARTNER login to the Partner whose data it may see.

enum UserRole {
  ADMIN
  PARTNER
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  /// Access level. ADMIN = full /admin back-office; PARTNER = /partner
  /// portal scoped to `partner` only. Existing rows default to ADMIN so
  /// this migration never downgrades a live admin.
  role      UserRole @default(ADMIN)
  /// Which Partner this login represents. Set only for PARTNER rows
  /// (enforced in the create/edit action); always null for ADMIN rows.
  /// onDelete: Restrict — a Partner with a login attached can't be
  /// deleted until that login is removed/reassigned, so a PARTNER row
  /// can never be orphaned with a dangling partnerId.
  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  // Bumped on logout / password change. JWTs carry the version they
  // were signed with; `requireAdmin()` rejects sessions where the
  // version no longer matches the DB, so a stolen cookie becomes
  // useless the moment the legit admin logs out.
  tokenVersion Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
}

// ── Business partners + revenue-share allocations ─────────────
// Models the "who owns what slice of each game" structure that the
// finance dashboard aggregates over. Two tables:
//   - Partner: the entities receiving payouts (free-form name +
//     contact string + optional admin note)
//   - ProductPartner: join table — for each (product, partner) pair
//     we store the share %, with the sum across one product
//     constrained to ≤ 100 (the leftover is the shared pool,
//     a.k.a. "เงินกลาง", and is purely a computed concept — no row
//     ever exists for it).
//
// Delete safety: ProductPartner cascades when its Product is deleted
// (the row is meaningless without the product) but does NOT cascade
// when a Partner is deleted. Deleting a Partner that still has rows
// here is rejected at the DB level — the admin must remove the
// shares first. This protects historical finance reports from
// silently losing rows.

model Partner {
  id      String  @id @default(cuid())
  /// Display name shown across admin UI + finance reports.
  name    String
  /// Free-form contact (email / phone / LINE id) — single field so
  /// admin can use whatever channel they actually reach the partner on.
  contact String?
  /// Internal admin note. Not shown anywhere customer-facing.
  note    String?

  shares ProductPartner[]
  /// Login accounts (AdminUser rows with role=PARTNER) that represent
  /// this partner in the /partner portal. Usually 0 or 1, but the
  /// schema allows several logins to share one Partner's view.
  users  AdminUser[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model ProductPartner {
  id           String  @id @default(cuid())
  productId    String
  partnerId    String
  /// Percentage of this product's revenue assigned to this partner.
  /// Stored as 0.00 – 100.00 (two decimals). The sum across all
  /// partners for one product is validated server-side to be ≤ 100.
  sharePercent Decimal @db.Decimal(5, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  partner Partner @relation(fields: [partnerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, partnerId])
  @@index([partnerId])
}
